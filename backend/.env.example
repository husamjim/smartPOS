# SmartPOS Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# USAGE: Copy this file to backend/.env and fill in your actual values.
# NEVER commit the actual .env file to git!

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# Use PostgreSQL in production (set DATABASE_URL), SQLite for local dev (leave empty)
DATABASE_URL=postgresql://smartpos_user:your_secure_password@localhost:5432/smartpos

# PostgreSQL Connection Pool
DB_POOL_MAX=20
DB_POOL_MIN=2

# PostgreSQL credentials (used in docker-compose)
POSTGRES_DB=smartpos
POSTGRES_USER=smartpos_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_DB_PASSWORD

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# CRITICAL: Use long random strings (min 64 chars). Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE_USE_CRYPTO_RANDOMBYTES_64
REFRESH_TOKEN_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_RANDOM_STRING_FOR_REFRESH

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://smartposoi.vercel.app,http://localhost:5173
